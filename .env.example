# TerraMind — variables de entorno del servidor
# Copie este archivo a .env y complete los valores.

# NASA FIRMS MAP_KEY (solicitar en https://firms.modaps.eosdis.nasa.gov/api/map_key/)
# NUNCA usar prefijo VITE_ — la clave solo vive en el servidor.
NASA_FIRMS_MAP_KEY=

# Puerto del motor de ingesta (API + scheduler)
TERRAMIND_PORT=3001

# Directorio de persistencia local (opcional, legacy — Commit 2+ usa Supabase)
# TERRAMIND_DATA_DIR=./data

# Supabase — SOLO servidor. NUNCA usar prefijo VITE_ para service role.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Anon key — server JWT validation + frontend login (VITE_ prefix for browser)
SUPABASE_ANON_KEY=
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=

# Auth enforcement (production defaults to true; dev may set AUTH_ENFORCE=false)
AUTH_ENFORCE=false
AUTH_TEST_MODE=0
AUTH_AUDIT_PERSIST=0
AUTH_DEV_ORG_ID=

# Análisis documental de noticias (Bloque N2) — solo servidor
OPENAI_API_KEY=
NEWS_LLM_FAST_MODEL=gpt-4o-mini
NEWS_LLM_DEEP_MODEL=gpt-4o
NEWS_LLM_ENABLED=false

# One-shot platform bootstrap (disable after first run)
AUTH_BOOTSTRAP_TOKEN=
AUTH_BOOTSTRAP_AUTH_USER_ID=
# Real auth smoke / activation (server-side only — never commit values)
AUTH_TEST_EMAIL=
AUTH_TEST_PASSWORD=
# 8B.7G pilot allowlist (server-side only — disable after pilot)
FIELD_REAL_SYNC_PILOT_ENABLED=false
FIELD_SYNC_PILOT_ORG_IDS=
FIELD_SYNC_PILOT_USER_IDS=
FIELD_SYNC_PILOT_MISSION_IDS=
TERRAMIND_APP_URL=http://localhost:5173

# Firma HMAC de paquetes offline (opcional; sin clave solo integridad SHA-256)
OFFLINE_PACKAGE_SIGNING_KEY=
