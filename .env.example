# TerraMind — variables de entorno del servidor
# Copie este archivo a .env y complete los valores.

# NASA FIRMS MAP_KEY (solicitar en https://firms.modaps.eosdis.nasa.gov/api/map_key/)
# NUNCA usar prefijo VITE_ — la clave solo vive en el servidor.
NASA_FIRMS_MAP_KEY=

# Puerto del motor de ingesta (API + scheduler)
TERRAMIND_PORT=3001

# Directorio de persistencia local (opcional, legacy — Commit 2+ usa Supabase)
# TERRAMIND_DATA_DIR=./data

# Supabase — SOLO servidor. NUNCA usar prefijo VITE_ para service role.
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
